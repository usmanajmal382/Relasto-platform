{
  "version": 2,
  "builds": [
    {
      "src": "backend_core/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend_core/wsgi.py"
    }
  ],
  "scripts": {
    "build": "sh build.sh"
  }
}
